<table class="table">
  <thead>
    <tr>
      <th scope="col">Title</th>
      <th scope="col">Body</th>
    </tr>
  </thead>
  <tbody>
      <% @article.comments.each do |comment| %>
        <% unless comment.archived? %>
        <tr>
          <td><%= comment.title %></td>
          <td><%= comment.body %></td>
        </tr>
      <% end %>
      <% end %>
  </tbody>
</table>
